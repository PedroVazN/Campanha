# Neon PostgreSQL
# Dashboard: https://console.neon.tech → Connection string
#
# DATABASE_URL = connection pooling (recomendada na app / Vercel)
# DIRECT_URL   = direct connection (migrate / db push / seed)

DATABASE_URL="postgresql://USER:PASSWORD@ep-XXXX-pooler.REGION.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@ep-XXXX.REGION.aws.neon.tech/neondb?sslmode=require"

# Auth — em produção use URL do app e um secret forte
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="troque-por-um-secret-longo-e-aleatorio"
